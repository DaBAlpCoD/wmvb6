Private Sub mnuTracer_Click()
   '-----------------------------------------------------
   '---------   Vťrifications avant   -------------------
   '--------- fermeture de la fenÍtre -------------------
   '-----------------------------------------------------
   '-----  1- Bornes ťcrites correctement  --------------
   On Error Resume Next
   Xmax = CSng(DefXmax.Text)
   If Err.Number <> 0 Then
      MsgBox "Xmax est incorrect", 48, "COURBE"
      Exit Sub
   End If
   Xmin = CSng(DefXmin.Text)
   If Err.Number <> 0 Then
      MsgBox "Xmin est incorrect", 48, "COURBE"
      Exit Sub
   End If
   Ymax = CSng(DefYmax.Text)
   If Err.Number <> 0 Then
      MsgBox "Ymax est incorrect", 48, "COURBE"
      Exit Sub
   End If
   Ymin = CSng(DefYmin.Text)
   If Err.Number <> 0 Then
      MsgBox "Ymin est incorrect", 48, "COURBE"
      Exit Sub
   End If
   Xvnd = CSng(DefXvnd.Text)
   If Err.Number <> 0 Then
      MsgBox "Xvnd est incorrect", 48, "COURBE"
      Exit Sub
   End If
   On Error GoTo 0
   '-----  2- Bornes dans le bon ordre  --------------
   AX = Xmax - Xmin
   If Ech% = 1 Then
      AY = AX * FE
      Ymax = Ymin + AY
   Else
      AY = Ymax - Ymin
   End If
   If AX < 0 Then
      MsgBox "Xmax doit Ítre supťrieur ŗ Xmin", 48, "COURBE"
      Exit Sub
   ElseIf AY < 0 Then
      MsgBox "Ymax doit Ítre supťrieur ŗ Ymin", 48, "COURBE"
      Exit Sub
   End If
   '-----------------------------------------------------
   '--------   fermeture de la fenÍtre   ----------------
   '--------      et ouverture           ----------------
   '--------  des fenÍtres pour le tracť ----------------
   '-----------------------------------------------------
   FenetreDefPrim.Hide
   Fenetre_Prin.Show
   Fenetre_Val.Show
   Dessin.Show
   '--------------------------------------------------------------
   '--------- Affichage de la (des) formule(s) -------------------
   '---------     dťfinissant la courbe        -------------------
   '--------------------------------------------------------------
   Fenetre_Prin.Caption = "Primitive d'une fonction f(X)"
   Fenetre_Prin.LabelExplications.ForeColor = MAGENTA
   Fenetre_Prin.LabelExplications.Caption = "Courbe Y(X) = somme de X0 ŗ X de f(t) dt" & Chr$(13) & "Rťsolution par la mťthode de SIMPSON."
   Fenetre_Val.Cls
   Fenetre_Val.ForeColor = CouleurCou&
   Fenetre_Val.lblFormule.ForeColor = CouleurCou&
   Fenetre_Val.lblFormule.Caption = "f(X) = " & TextVar2$
   Fenetre_Val.lblNote.ForeColor = CouleurCou&
   TexteNote$ = "Zťro de la fonction Y(X) pour X0 = "
   TexteNote$ = TexteNote$ & Format(DefXvnd.Text, "0.0000")
   Fenetre_Val.lblNote.Caption = TexteNote$
End Sub

