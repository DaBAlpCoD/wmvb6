End Sub

Private Sub mnuOuvPoints_Click()
   On Error GoTo Traite_ErreursOuvPts
   Maths.ctrlCMDialog.Filter = "Points (*.xy)|*.xy"
   ' nom de fichier et chemin doivent exister
   ' sinon apparait un message d'erreur spťcifique
   Maths.ctrlCMDialog.Flags = &H1000& Or &H800&
   Maths.ctrlCMDialog.CancelError = True
   Maths.ctrlCMDialog.Action = 1
   '-----------------------------------------------------
   ' Ouverture et lecture du fichier de points
   ' et ťcriture de leurs coordonnťes dans Xpt() et Ypt()
   '-----------------------------------------------------
   Open Maths.ctrlCMDialog.filename For Input As #1
   Input #1, NbPts%
   ReDim Xpt(1 To NbPts%)
   ReDim Ypt(1 To NbPts%)
   For iloc% = 1 To NbPts%
    Input #1, Xpt(iloc%)
    Input #1, Ypt(iloc%)
   Next iloc%
   Close #1
   '-----------------------------------------------------
   ' activation de certaines cases
   '-------------------------------
   EtiquettePoints.ForeColor = &H80000012     'Texte activť
   PointsTracer.ForeColor = &H80000012        'Texte activť
   PointsTracer.Value = 1                         'Checked
   PointsRelier.ForeColor = &H80000012        'Texte activť
   PointsRelier.Value = 0                         'Unchecked
   EtiquetteCoulPoints.ForeColor = &H80000012 'Texte activť
   EtiquetteCoulPtsChoisie.ForeColor = &H80000012 'Texte activť
   '-----------------------------------------------------
   Exit Sub
Traite_ErreursOuvPts:
   Select Case Err
      Case 32755
         ' bouton Annuler
      Case Else
         Close #1
         MsgBox Error$, 48
   End Select
   Exit Sub
End Sub

